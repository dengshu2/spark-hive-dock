<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<!--
  Hadoop Core Configuration (Spark copy)
  - Sets default filesystem to HDFS on namenode
  - Configures proxy user for Hive
  - Enables Kerberos authentication
-->
<configuration>
    <!-- Default filesystem URI -->
    <property>
        <name>fs.defaultFS</name>
        <value>hdfs://namenode.hive-net:9000</value>
    </property>

    <!-- Proxy user settings for Hive -->
    <property>
        <name>hadoop.proxyuser.root.hosts</name>
        <value>*</value>
    </property>
    <property>
        <name>hadoop.proxyuser.root.groups</name>
        <value>*</value>
    </property>
    <property>
        <name>hadoop.proxyuser.hive.hosts</name>
        <value>*</value>
    </property>
    <property>
        <name>hadoop.proxyuser.hive.groups</name>
        <value>*</value>
    </property>
    <property>
        <name>hadoop.proxyuser.spark.hosts</name>
        <value>*</value>
    </property>
    <property>
        <name>hadoop.proxyuser.spark.groups</name>
        <value>*</value>
    </property>

    <!-- Kerberos authentication -->
    <property>
        <name>hadoop.security.authentication</name>
        <value>kerberos</value>
    </property>
    <property>
        <name>hadoop.security.authorization</name>
        <value>true</value>
    </property>
    <property>
        <name>hadoop.rpc.protection</name>
        <value>authentication</value>
    </property>

    <!-- Disable FileSystem cache: prevents Hive from closing a shared
         DFSClient that Spark Thrift Server still needs (HIVE-3.1.3 bug) -->
    <property>
        <name>fs.hdfs.impl.disable.cache</name>
        <value>true</value>
    </property>
</configuration>
