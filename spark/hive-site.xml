<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<!--
  Spark Hive Metastore Client Configuration
  - Connects Spark SQL to the Hive Metastore service
  - Kerberos SASL authentication for Metastore
-->
<configuration>
    <property>
        <name>hive.metastore.uris</name>
        <value>thrift://hive-metastore.hive-net:9083</value>
    </property>
    <property>
        <name>hive.metastore.warehouse.dir</name>
        <value>/user/hive/warehouse</value>
    </property>

    <!-- Kerberos: client-side SASL for Metastore Thrift -->
    <property>
        <name>hive.metastore.sasl.enabled</name>
        <value>true</value>
    </property>
    <property>
        <name>hive.metastore.kerberos.principal</name>
        <value>hive/_HOST@EXAMPLE.COM</value>
    </property>
    

    <!-- Thrift Server authentication -->
    <property>
        <name>hive.server2.authentication</name>
        <value>KERBEROS</value>
    </property>
    <property>
        <name>hive.server2.authentication.kerberos.principal</name>
        <value>spark/_HOST@EXAMPLE.COM</value>
    </property>
    <property>
        <name>hive.server2.authentication.kerberos.keytab</name>
        <value>/etc/security/keytabs/spark.keytab</value>
    </property>

    <!-- Disable user impersonation for MetaStore calls.
         When enabled, Thrift Server impersonates the connecting user,
         but the impersonated user has no Kerberos TGT in Docker.
         With doAs=false, Spark uses its own service principal. -->
    <property>
        <name>hive.server2.enable.doAs</name>
        <value>false</value>
    </property>
</configuration>
