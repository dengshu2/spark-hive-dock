# ============================================================
# Docker Hive Cluster - Environment Variables
# Copy this file to .env and customize as needed:
#   cp .env.example .env
# ============================================================

# Component Versions
HADOOP_VERSION=3.3.6
HIVE_VERSION=3.1.3
SPARK_VERSION=3.5.3
MYSQL_VERSION=8.0

# MySQL Configuration
MYSQL_ROOT_PASSWORD=<CHANGE_ME>
MYSQL_DATABASE=hive_metastore
MYSQL_USER=hive
MYSQL_PASSWORD=<CHANGE_ME>

# HDFS Configuration
HDFS_REPLICATION=1

# ============================================================
# Download Mirror Configuration (for faster builds)
# ============================================================
# Chinese mirrors (recommended for users in China):
#   - Tsinghua: https://mirrors.tuna.tsinghua.edu.cn/apache
#   - Aliyun:   https://mirrors.aliyun.com/apache
# Default Apache mirrors:
#   - Hadoop:   https://dlcdn.apache.org
#   - Spark/Hive: https://archive.apache.org/dist
# ============================================================
# Uncomment and modify for faster downloads in China:
# APACHE_MIRROR_HADOOP=https://mirrors.tuna.tsinghua.edu.cn/apache
# APACHE_MIRROR_SPARK=https://mirrors.tuna.tsinghua.edu.cn/apache
# APACHE_MIRROR_HIVE=https://mirrors.tuna.tsinghua.edu.cn/apache
