# ============================================================
# Docker Hive Cluster - Environment Variables
# Copy this file to .env and customize as needed:
#   cp .env.example .env
# ============================================================

# Component Versions
HADOOP_VERSION=3.3.6
HIVE_VERSION=3.1.3
SPARK_VERSION=3.5.3
MYSQL_VERSION=8.0

# MySQL Configuration
MYSQL_ROOT_PASSWORD=<CHANGE_ME>
MYSQL_DATABASE=hive_metastore
MYSQL_USER=hive
MYSQL_PASSWORD=<CHANGE_ME>

# HDFS Configuration
HDFS_REPLICATION=1

# Timezone (applied to all containers)
TZ=Asia/Shanghai
